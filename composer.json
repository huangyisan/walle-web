{
    "name": "meolu/walle-web",
    "description": "A web deployment tool",
    "keywords": ["walle", "php deploy", "deploy web", "deploy ui"],
    "homepage": "http://www.huamanshu.com/walle-en.html",
    "type": "project",
    "license": "BSD-3-Clause",
    "minimum-stability": "stable",
    "require": {
        "php": ">=8.0",
        "yiisoft/yii2": "~2.0.49",
        "yiisoft/yii2-bootstrap": "~2.0.11",
        "yiisoft/yii2-symfonymailer": "~2.0.4"
    },
    "require-dev": {
        "yiisoft/yii2-debug": "~2.1.0",
        "yiisoft/yii2-gii": "~2.2.0",
        "yiisoft/yii2-faker": "~2.0.0"
    },
    "config": {
        "process-timeout": 1800,
        "allow-plugins": {
            "yiisoft/yii2-composer": true
        }
    },
    "repositories": [
        {
            "type": "composer",
            "url": "https://asset-packagist.org"
        }
    ],
    "extra": {
        "asset-installer-paths": {
            "npm-asset-library": "vendor/npm",
            "bower-asset-library": "vendor/bower"
        }
    }
}
