# 复制为 .env 后修改：cp .env.example .env

WALLE_HTTP_PORT=8080

# 宿主机 MySQL（容器通过 host.docker.internal 连接）
WALLE_DB_HOST=host.docker.internal
WALLE_DB_NAME=walle
WALLE_DB_USER=root
WALLE_DB_PASS=你的宿主机mysql密码

WALLE_COOKIE_KEY=请改成随机字符串

# 若 host.docker.internal 不通，可改为宿主机内网 IP，例如：
# WALLE_DB_HOST=192.168.0.31

# SSH 密钥目录（默认 ./docker/ssh）
# WALLE_SSH_DIR=/home/ubuntu/.ssh
